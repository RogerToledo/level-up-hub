# Application Settings
ENV=dev
PORT=8081

# Database Connection
DB_URL_DEV=postgres://user:password@localhost:5432/leveluphub_dev?sslmode=disable
DB_URL_PROD=postgres://user:password@localhost:5432/leveluphub_prod?sslmode=require

# Connection Pool Configuration
# Increase in production based on expected load
MAX_CONNS=25              # Maximum simultaneous connections (default: 25)
MIN_CONNS=5               # Minimum connections maintained (default: 5)
MAX_CONN_LIFETIME=3600    # Maximum connection lifetime in seconds (default: 1 hour)
MAX_CONN_IDLE_TIME=1800   # Maximum idle time before closing in seconds (default: 30 min)
HEALTH_CHECK_PERIOD=60    # Interval between health checks in seconds (default: 60s)
CONNECT_TIMEOUT=5         # Timeout to establish connection in seconds (default: 5s)

# Environment Recommendations:
# Development: MAX_CONNS=10, MIN_CONNS=2
# Staging: MAX_CONNS=25, MIN_CONNS=5
# Production: MAX_CONNS=50-100, MIN_CONNS=10-25 (adjust based on load)

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Observabilidade
LOG_LEVEL=info              # debug, info, warn, error
LOG_FORMAT=json             # text, json
ENABLE_POOL_MONITOR=true    # Enable pool stats monitoring
POOL_MONITOR_INTERVAL=60    # Stats logging interval (seconds)

# Swagger/OpenAPI
SWAGGER_ENABLED=true
SWAGGER_HOST=localhost:8081
SWAGGER_BASE_PATH=/v1

# CORS (if needed)
# CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001
# CORS_ALLOWED_METHODS=GET,POST,PUT,DELETE,OPTIONS
# CORS_ALLOWED_HEADERS=Authorization,Content-Type
