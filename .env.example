# Application Settings
ENV=dev
PORT=8081

# Database Connection
DB_URL_DEV=postgres://user:password@localhost:5432/leveluphub_dev?sslmode=disable
DB_URL_PROD=postgres://user:password@localhost:5432/leveluphub_prod?sslmode=require

# Connection Pool Configuration
# Aumentar em produção baseado na carga esperada
MAX_CONNS=25              # Máximo de conexões simultâneas (default: 25)
MIN_CONNS=5               # Mínimo de conexões mantidas (default: 5)
MAX_CONN_LIFETIME=3600    # Vida máxima de uma conexão em segundos (default: 1 hora)
MAX_CONN_IDLE_TIME=1800   # Tempo máximo idle antes de fechar em segundos (default: 30 min)
HEALTH_CHECK_PERIOD=60    # Intervalo entre health checks em segundos (default: 60s)
CONNECT_TIMEOUT=5         # Timeout para estabelecer conexão em segundos (default: 5s)

# Recomendações por Ambiente:
# Desenvolvimento: MAX_CONNS=10, MIN_CONNS=2
# Staging: MAX_CONNS=25, MIN_CONNS=5
# Produção: MAX_CONNS=50-100, MIN_CONNS=10-25 (ajustar baseado na carga)

# Security
JWT_SECRET=your-super-secret-jwt-key-change-in-production

# Observabilidade
# Para ambientes com logging estruturado, considere adicionar:
# LOG_LEVEL=info  # debug, info, warn, error
# LOG_FORMAT=json # text, json
