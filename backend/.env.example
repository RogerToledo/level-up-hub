# Database Configuration
DB_URL_DEV=postgres://user:password@localhost:5432/leveluphub_dev?sslmode=disable
DB_URL_PROD=postgres://user:password@localhost:5432/leveluphub_prod?sslmode=disable

# Server Configuration
PORT=8081
ENV=dev

# Database Connection Pool Settings
MAX_CONNS=25
MIN_CONNS=5
MAX_CONN_LIFETIME=3600
MAX_CONN_IDLE_TIME=1800
HEALTH_CHECK_PERIOD=60
CONNECT_TIMEOUT=5

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production

# Email/SMTP Configuration
# Para Gmail, use smtp.gmail.com com porta 587
# Você precisará gerar uma "Senha de App" em: https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM=noreply@leveluphub.com
SMTP_FROM_NAME=Level Up Hub
